rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 유저: 본인만 쓰기, 모든 로그인 유저 읽기
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // 게시물: 모든 로그인 유저 읽기, 본인만 생성/수정
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.content.size() <= 280;
      allow update: if request.auth != null
        && (resource.data.authorUid == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['likeCount', 'commentCount']));

      // 댓글
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid;
        allow update: if request.auth != null
          && resource.data.authorUid == request.auth.uid;
      }
    }

    // 좋아요: 본인 키로만 생성/삭제
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && likeId == request.resource.data.postId + '_' + request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userUid == request.auth.uid;
    }
  }
}
